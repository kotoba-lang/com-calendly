// Calendly clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace calendly {

    entity Workspace {
        id: string @unique
        name: string
        ownerId: string
        plan: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Document {
        id: string @unique
        workspaceId: string
        title: string
        contentRef: string
        ownerId: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Folder {
        id: string @unique
        workspaceId: string
        name: string
        parentId: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Comment {
        id: string @unique
        documentId: string
        authorId: string
        body: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Permission {
        id: string @unique
        resourceId: string
        principalId: string
        role: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity User {
        id: string @unique
        email: string
        displayName: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
